# Environment variables for the DB API layer (ADR-006 / ADR-007).
# Copy this file to .env.local and fill in real values. .env.local is gitignored.
#
#   cp .env.example .env.local
#
# All three are read SERVER-SIDE only (inside src/app/api/courses route handlers
# and scripts). None are exposed to the browser — the app never queries Supabase
# directly (see ADR-007).

# Supabase project URL — from the Supabase dashboard (Project Settings → API).
# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service_role key — full-access server key. Used by the API route to
# read/write the DB. NEVER expose this to the browser or commit it.
SUPABASE_SECRET_KEY=

# Shared secret that gates POST /api/courses (bulk upsert). Any long random
# string; the same value must be sent by write clients in the X-Api-Key header.
# Generate one with:  openssl rand -hex 32
API_WRITE_SECRET=
