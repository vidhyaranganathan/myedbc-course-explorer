#!/bin/sh
# Pre-push hook: run lint, test, and build before pushing
# Catches failures locally instead of waiting for CI

echo "🔍 Running pre-push checks..."

echo ""
echo "── Lint ──"
npm run lint
if [ $? -ne 0 ]; then
  echo "❌ Lint failed. Push aborted."
  exit 1
fi

echo ""
echo "── Tests + Coverage ──"
npm run test:coverage
if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Push aborted."
  exit 1
fi

echo ""
echo "── Build ──"
npm run build
if [ $? -ne 0 ]; then
  echo "❌ Build failed. Push aborted."
  exit 1
fi

echo ""
echo "✅ All checks passed. Pushing..."
